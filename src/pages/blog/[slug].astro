---
import Layout from "../../layouts/Layout.astro";
import { getCollection } from "astro:content";

// Generate static paths for all blog posts
export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();
---

<Layout
  title={post.data.title}
  isBlog={true}
  postTitle={post.data.title}
  pubDate={post.data.pubDate}
  description={post.data.description}
  tags={post.data.tags}
>
  <article class="-mt-6">
    <div class="prose dark:prose-invert max-w-none">
      <h1 class="text-3xl sm:text-5xl font-bold mb-2">{post.data.title}</h1>
      <p class="text-neutral-500 text-sm mb-8">
        {
          post.data.pubDate.toLocaleDateString("en-US", {
            year: "numeric",
            month: "long",
            day: "numeric",
          })
        }
      </p>
      {post.data.tags && post.data.tags.length > 0 && (
        <div class="flex flex-wrap gap-2 mb-6">
          {post.data.tags.map((tag) => (
            <button data-tag-link={tag} class="px-3 py-1 text-xs text-gray-600 dark:text-gray-400 rounded hover:opacity-60 transition-opacity cursor-pointer">
              #{tag}
            </button>
          ))}
        </div>
      )}
      <Content />
    </div>

    <!-- <footer class="mt-12 pt-8 border-t border-gray-200 dark:border-gray-700"> -->
    <!-- Footer content can go here -->
    <!-- </footer> -->
  </article>
</Layout>

<style>
  /* Blog content styling */
  :global(.prose) {
    color: inherit;
  }

  :global(.prose h2) {
    margin-top: 1.5em;
    margin-bottom: 0.5em;
    font-size: 1.5em;
    font-weight: 600;
  }

  :global(.prose h3) {
    margin-top: 1.25em;
    margin-bottom: 0.5em;
    font-size: 1.25em;
    font-weight: 600;
  }

  :global(.prose p) {
    margin-bottom: 1em;
    line-height: 1.75;
  }

  :global(.prose ul),
  :global(.prose ol) {
    margin-bottom: 1em;
    padding-left: 1.5em;
  }

  :global(.prose li) {
    margin-bottom: 0.5em;
  }

  :global(.prose code) {
    background-color: #eef2ff;
    padding: 0.2em 0.45em;
    border-radius: 0.35em;
    border: 1px solid rgba(59, 130, 246, 0.15);
    font-size: 0.9em;
    color: #1f2937;
  }

  :global(.dark .prose code) {
    background-color: #111827;
    border-color: rgba(148, 163, 184, 0.25);
    color: #e5e7eb;
  }

  :global(.prose pre) {
    background-color: #f8fafc;
    padding: 1em;
    border-radius: 0.75em;
    overflow-x: auto;
    margin-bottom: 1em;
    border: 1px solid #e5e7eb;
  }

  :global(.dark .prose pre) {
    background-color: #111827;
    border-color: #374151;
  }

  :global(.prose table) {
    width: 100%;
    display: block;
    overflow-x: auto;
    border-collapse: collapse;
    margin-bottom: 1em;
  }

  :global(.prose th),
  :global(.prose td) {
    padding: 0.85rem 1rem;
    border: 1px solid #e5e7eb;
  }

  :global(.dark .prose th),
  :global(.dark .prose td) {
    border-color: #374151;
  }

  :global(.prose thead) {
    background-color: #f8fafc;
  }

  :global(.dark .prose thead) {
    background-color: #111827;
  }

  :global(.prose blockquote) {
    border-left: 4px solid #d1d5db;
    padding-left: 1em;
    margin-left: 0;
    margin-bottom: 1em;
    font-style: italic;
  }

  :global(.dark .prose blockquote) {
    border-left-color: #4b5563;
  }

  :global(.prose img) {
    margin: 0;
    padding: 0;
    width: 100%;
    max-width: none;
  }

  :global(.prose p:has(img)) {
    margin: 0;
    padding: 0;
  }

  /* Strip per-token backgrounds Shiki injects */
  :global(.prose pre span) {
    background-color: transparent !important;
  }
</style>

<script>
  const tagLinks = document.querySelectorAll('[data-tag-link]') as NodeListOf<HTMLButtonElement>;
  
  tagLinks.forEach((button) => {
    button.addEventListener('click', (e) => {
      e.preventDefault();
      const tag = button.getAttribute('data-tag-link');
      if (tag) {
        window.location.href = `/blog?tag=${encodeURIComponent(tag)}`;
      }
    });
  });
</script>
