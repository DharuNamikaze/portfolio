---
import '../styles/global.css';
import Analytics from '@vercel/analytics/astro';

interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="Minimalist Portfolio" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<Analytics />
	</head>	
	<body class="font-sans antialiased">
		<main class="max-w-3xl mx-auto px-6 py-4 min-h-screen flex flex-col">
			<slot />
            <!-- Simple Footer -->
            <footer class="mt-auto pt-20 text-xs">
                &copy; {new Date().getFullYear()}
            </footer>
		</main>
	</body>
</html>