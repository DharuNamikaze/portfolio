---
import '../styles/global.css';
import Analytics from '@vercel/analytics/astro';
import Header from '../components/Header.astro';
import { Font } from 'astro:assets';

interface Props {
  title: string;
  isBlog?: boolean;
  postTitle?: string;
  pubDate?: string | Date;
  description?: string;
  ogImage?: string;
  tags?: string[];
}

const {
  title,
  isBlog = false,
  postTitle = '',
  pubDate = '',
  description = 'Dharun R — Full-stack engineer building scalable systems.',
  ogImage = '/og-default.png',
  tags = [],
} = Astro.props;

const siteUrl = 'https://dharun-builds.vercel.app';
const canonicalURL = new URL(Astro.url.pathname, siteUrl).href;
const pageTitle = isBlog && postTitle ? postTitle : 'Dharun R';
const ogImageURL = new URL(ogImage, siteUrl).href;

// JSON-LD structured data
const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Dharun R',
  url: siteUrl,
  sameAs: [
    'https://github.com/DharuNamikaze',
    'https://www.linkedin.com/in/dharunn/',
    'https://x.com/Dharu_Namikaze',
  ],
  jobTitle: 'Full-Stack Engineer',
};

const articleSchema = isBlog && postTitle ? {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: postTitle,
  description,
  author: { '@type': 'Person', name: 'Dharun R', url: siteUrl },
  datePublished: pubDate ? new Date(pubDate).toISOString() : undefined,
  url: canonicalURL,
  keywords: tags.join(', '),
  publisher: { '@type': 'Person', name: 'Dharun R', url: siteUrl },
} : null;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="color-scheme" content="light dark" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <Font cssVariable="--font-inter" preload />
    <meta name="generator" content={Astro.generator} />

    <!-- Primary -->
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    {tags.length > 0 && <meta name="keywords" content={tags.join(', ')} />}
    <meta name="author" content="Dharun R" />
    <meta name="robots" content="index, follow" />

    <!-- Open Graph -->
    <meta property="og:type" content={isBlog ? 'article' : 'website'} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:site_name" content="Dharun R" />
    <meta property="og:locale" content="en_US" />
    {isBlog && pubDate && <meta property="article:published_time" content={new Date(pubDate).toISOString()} />}
    {isBlog && tags.map((tag) => <meta property="article:tag" content={tag} />)}

    <!-- Twitter / X -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@Dharu_Namikaze" />
    <meta name="twitter:creator" content="@Dharu_Namikaze" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />

    <!-- JSON-LD -->
    <script type="application/ld+json" set:html={JSON.stringify(articleSchema ?? personSchema)} />

    <!-- Umami analytics -->
    <script is:inline defer src="https://cloud.umami.is/script.js" data-website-id="e4a5e7a0-004d-4511-a462-33ecba9eeeb4"></script>
  </head>
  <body class="antialiased">
    <main class="max-w-3xl mx-auto px-6 py-4 min-h-screen flex flex-col">
      <Header isBlog={isBlog} postTitle={postTitle} pubDate={pubDate} />
      <slot />
      <footer class="mt-auto pt-20 text-xs">
        &copy; {new Date().getFullYear()}
      </footer>
    </main>
    <Analytics />
  </body>
</html>
