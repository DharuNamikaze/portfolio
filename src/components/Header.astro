---
import ThemeToggle from "./ThemeToggle.astro";
import { readFileSync } from "fs";
import path from "path";

interface Props {
  isBlog?: boolean;
  postTitle?: string;
  pubDate?: string | Date;
}

const { isBlog = false, postTitle = "", pubDate = "" } = Astro.props;

const Handles = [
  {
    name: "Linkedin",
    img: "linkedin.svg",
    url: "https://www.linkedin.com/in/dharunn/",
  },
  { name: "X", img: "x.svg", url: "https://x.com/Dharu_Namikaze" },
  {
    name: "Github",
    img: "github.svg",
    url: "https://github.com/DharuNamikaze/",
  },
  { name: "Mail", img: "mail.svg", url: "mailto:dharunamikaze@gmail.com" },
  { name: "Resume", img: "resume.svg", url: "/Dharun_CV.pdf" },
];

// Read SVG files at build time so we can inline them (currentColor works with inline SVGs)
const publicDir = path.resolve("public");
const handlesWithSvg = Handles.map((handle) => {
  try {
    const svgPath = path.join(publicDir, handle.img);
    const svgContent = readFileSync(svgPath, "utf-8");
    return { ...handle, svgContent };
  } catch {
    return { ...handle, svgContent: null };
  }
});

let formattedDate = "";
if (pubDate) {
  const d = typeof pubDate === "string" ? new Date(pubDate) : (pubDate as Date);
  formattedDate = d.toLocaleDateString("en-US", {
    month: "long",
    day: "numeric",
    year: "numeric",
  });
}
---

<header class="mb-10">
  <div class="flex flex-col gap-3 mb-4 mt-5">
    <div class="flex justify-between items-center">
      <a href="/" class="text-2xl max-sm:text-xl font-bold hover:underline cursor-pointer" aria-label="Go to home">
        Dharun / தருண்
      </a>
      <div class="flex gap-3 items-center">
        {/* Desktop only: icon links */}
        {
          handlesWithSvg.map((handle) => (
            <a
              href={handle.url}
              title={handle.name}
              class="social-link sm:inline-flex hidden"
              target="_blank"
              rel="noopener noreferrer"
            >
              {handle.svgContent ? (
                <span class="social-icon" set:html={handle.svgContent} />
              ) : (
                <img src={`/${handle.img}`} alt={handle.name} class="social-icon" loading="lazy" />
              )}
            </a>
          ))
        }
        {/* Theme toggle always visible */}
        <ThemeToggle />
      </div>
    </div>

    {/* Mobile only: compact text link row */}
    <div class="flex sm:hidden gap-4 text-xs opacity-60 flex-wrap">
      {
        handlesWithSvg.map((handle) => (
          <a
            href={handle.url}
            class="hover:opacity-100 transition-opacity"
            target="_blank"
            rel="noopener noreferrer"
          >
            {handle.name.toLowerCase()}
          </a>
        ))
      }
    </div>
    {
      !isBlog && (
        <nav class="flex gap-6 text-sm border-t pt-3 border-gray-200 dark:border-gray-800 flex-wrap">
          <a href="/freelance" class="nav-link">Freelance</a>
          <a href="/blog" class="nav-link">Blog</a>
        </nav>
      )
    }
  </div>
  {
    !isBlog && (
      <p class="leading-relaxed">
        Started coding by myself with web-basics, shifted to
        <a href="https://react.dev/" target="_blank" rel="noopener noreferrer">
          react
        </a>
        -
        <a
          href="https://nodejs.org/en"
          target="_blank"
          rel="noopener noreferrer"
        >
          express
        </a>
        , picked{" "}
        <a href="https://nextjs.org/" target="_blank" rel="noopener noreferrer">
          nextjs
        </a>
        , then built{" "}
        <a
          href="https://qaweb.mymapit.in/chat/"
          target="_blank"
          rel="noopener noreferrer"
        >
          AgentHub
        </a>{" "}
        for{" "}
        <a href="https://myanatomy.ai/" rel="noopener noreferrer">
          MyAnatomy Inc
        </a>{" "}
        (got scammed), curiously made this Antigravity feature open-source to
        all IDEs and wrapped in npm package{" "}
        <a href="https://github.com/DharuNamikaze/Paylog.git" target="_blank" rel="noopener noreferrer">
          Gravity
        </a>
        . Created this for fun but acutally reached 20k+ page visits in 3 days
        checkout:{" "}
        <a
          href="http://deep-ml-trench.vercel.app"
          target="_blank"
          rel="noopener noreferrer"
        >
          Deep-ML-Trench
        </a>
        , now developing the v2 with threejs{" "}
        <a
          href="https://github.com/DharuNamikaze/TheMLTrench"
          target="_blank"
          rel="noopener noreferrer"
        >
          Deep-ML-Space
        </a>
        .
        <br />
        <br />
        <code>&#123; core_interests: ["Math", "ML", "Fullstack"] &#125;</code>
        <br />
        Currently building
        <a
          href="https://www.linuxfromscratch.org/"
          target="_blank"
          rel="noopener noreferrer"
        >
          linuxfromscratch
        </a>
        (my very own distro :D).
      </p>
    )
  }
</header>
