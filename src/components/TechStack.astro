---
import * as si from "simple-icons";

interface Props {
  stack: string[];
}

const { stack } = Astro.props;

// Map display names to simple-icons slug keys
const techIconMap: Record<string, string | undefined> = {
  React: "siReact",
  Express: "siExpress",
  MongoDB: "siMongodb",
  Astro: "siAstro",
  Three: "siThreedotjs",
  Typescript: "siTypescript",
  MCP: "siModelcontextprotocol",
  Npm: "siNpm",
  Next: "siNextdotjs",
  FFMPEG: "siFfmpeg",
  WA: "siWebassembly",
  Python: "siPython",
  Node: "siNodedotjs",
  AWS: "siAmazonwebservices",
  Docker: "siDocker",
  Medusa: "siMedusa",
  Razorpay: "siRazorpay",
  Namecheap: "siNamecheap",
  Pinecone: undefined, // no simple-icons entry
  Neon: "siNeon",
};

interface IconEntry {
  tech: string;
  svg: string | null;
  hex: string | null;
}

const icons: IconEntry[] = stack.map((tech) => {
  const key = techIconMap[tech];
  if (!key) return { tech, svg: null, hex: null };
  const icon = (si as Record<string, { svg: string; hex: string } | undefined>)[key];
  if (!icon) return { tech, svg: null, hex: null };
  // For black icons use invert trick; for others bake the brand color into the SVG fill
  const hex = icon.hex === "000000" ? null : icon.hex;
  const fillColor = hex ? `#${hex}` : "currentColor";
  const svg = icon.svg.replace('fill="currentColor"', `fill="${fillColor}"`);
  return { tech, svg, hex };
});
---

<div class="tech-stack-container">
  <div
    class="flex gap-2 items-center max-h-0 overflow-hidden group-hover:max-h-20 transition-all duration-500 ease-in-out"
  >
    {
      icons.map(({ tech, svg, hex }) => {
        if (!svg) {
          return (
            <span
              title={tech}
              class="text-[10px] font-mono px-1 py-0.5 rounded border border-gray-300 dark:border-gray-600 text-gray-500 dark:text-gray-400 leading-none mt-1"
            >
              {tech}
            </span>
          );
        }
        const isBlack = hex === null;
        return (
          <span
            title={tech}
            class={`inline-block w-5 h-5 mt-1 drop-shadow-sm [&>svg]:w-5 [&>svg]:h-5 ${isBlack ? "dark:invert" : ""}`}
            set:html={svg}
          />
        );
      })
    }
  </div>
</div>
